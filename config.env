CONFIG_ENV=config.env

# Kernel Source: Official OnePlus MT6893 (Nord 2/2T base)
# Ensure this URL is the complete link to your chosen kernel source
KERNEL_SOURCE=https://github.com/OnePlusOSS/android_kernel_oneplus_mt6893
KERNEL_SOURCE_BRANCH=oneplus/mt6893_11
KERNEL_CONFIG=oplus6893_defconfig
KERNEL_IMAGE_NAME=Image.gz-dtb
ARCH=arm64
ADD_LOCALVERSION_TO_FILENAME=false
EXTRA_CMDS=LLVM=1 LLVM_IAS=1

# Clang Settings: Set to r487747c for Android 14 compatibility 
USE_CUSTOM_CLANG=false
CUSTOM_CLANG_SOURCE=
CUSTOM_CLANG_BRANCH=
CUSTOM_CMDS:CLANG_TRIPLE=aarch64-linux-gnu-

CLANG_BRANCH=master-kernel-build-2023
CLANG_VERSION=r487747c

# GCC Toolchains
ENABLE_GCC_ARM64=true
ENABLE_GCC_ARM32=true
USE_CUSTOM_GCC_64=false
CUSTOM_GCC_64_SOURCE=
CUSTOM_GCC_64_BRANCH=
CUSTOM_GCC_64_BIN=aarch64-linux-android-
USE_CUSTOM_GCC_32=false
CUSTOM_GCC_32_SOURCE=
CUSTOM_GCC_32_BRANCH=
CUSTOM_GCC_32_BIN=arm-linux-androideabi-

# KernelSU Flags: v0.9.5 is the last version supporting non-GKI 
ENABLE_KERNELSU=true
KERNELSU_TAG=v0.9.5
KSU_EXPECTED_SIZE=0x033b
KSU_EXPECTED_HASH=c371061b19d8c7d7d6133c6a9bafe198fa944e50c1b31c9d8daa8d7f1fc2d2d6

# Build Configuration
DISABLE-LTO=false
DISABLE_CC_WERROR=true
ADD_KPROBES_CONFIG=true
ADD_OVERLAYFS_CONFIG=true
APPLY_KSU_PATCH=true
REMOVE_UNUSED_PACKAGES=true

# AnyKernel3 Settings
USE_CUSTOM_ANYKERNEL3=false
CUSTOM_ANYKERNEL3_SOURCE=
CUSTOM_ANYKERNEL3_BRANCH=

# Ccache for faster builds
ENABLE_CCACHE=true

# DTBO image: Required for MediaTek Nord devices
NEED_DTBO=true

# Build boot images: Using your uploaded boot.img 
BUILD_BOOT_IMG=true
SOURCE_BOOT_IMAGE=https://raw.githubusercontent.com/Brodi-g/KernelSU_Nord2T_KSU/main/boot/boot.img